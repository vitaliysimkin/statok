      "checkConstraints": {
        "tx_amount_nonneg_check": {
          "name": "tx_amount_nonneg_check",
          "value": "\"transactions\".\"amount_minor\" IS NULL OR \"transactions\".\"amount_minor\" >= 0"
        },
        "tx_qty_positive_check": {
          "name": "tx_qty_positive_check",
          "value": "\"transactions\".\"quantity\" IS NULL OR \"transactions\".\"quantity\" > 0"
        },
        "tx_fee_only_trade_check": {
          "name": "tx_fee_only_trade_check",
          "value": "\"transactions\".\"type\" IN ('buy','sell') OR \"transactions\".\"fee_minor\" = 0"
        },
        "tx_transfer_group_check": {
          "name": "tx_transfer_group_check",
          "value": "(\"transactions\".\"type\" IN ('transfer_out','transfer_in')) = (\"transactions\".\"transfer_group_id\" IS NOT NULL)"
        },
        "tx_income_fields_check": {
          "name": "tx_income_fields_check",
          "value": "\n    \"transactions\".\"type\" NOT IN ('dividend','coupon','interest')\n    OR (\"transactions\".\"gross_minor\" IS NOT NULL AND \"transactions\".\"withholding_tax_minor\" IS NOT NULL\n        AND \"transactions\".\"net_minor\" = \"transactions\".\"gross_minor\" - \"transactions\".\"withholding_tax_minor\")"
        },
        "tx_trade_fields_check": {
          "name": "tx_trade_fields_check",
          "value": "\n    \"transactions\".\"type\" NOT IN ('buy','sell')\n    OR (\"transactions\".\"quantity\" IS NOT NULL AND \"transactions\".\"price\" IS NOT NULL AND \"transactions\".\"amount_minor\" IS NOT NULL)"
        }
