DATABASE_URL=postgresql://postgres:postgres@localhost:5434/statok
JWT_SECRET=dev-secret-change-me-minimum-32-chars!!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
BASE_CURRENCY=USD
PORT=3100
TZ=Europe/Kyiv
CORS_ORIGINS=http://localhost:5273
# Google sign-in (google-auth-task §2.1). Empty GOOGLE_CLIENT_ID in dev is OK:
# /auth/google then returns 503 AUTH_NOT_CONFIGURED. Fill it to test the flow.
GOOGLE_CLIENT_ID=
ALLOWED_GOOGLE_EMAIL=vitaliy.simkin@gmail.com
# Break-glass password login: enabled in dev, OFF in prod (.env without =true).
ENABLE_PASSWORD_LOGIN=true
